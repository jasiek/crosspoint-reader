# provision-server.sh — Configuration
#
# Copy this to .env and fill in values before running:
#   cp provision-server.env.example .env
#   vim .env
#   sudo ./provision-server.sh --env-file .env

# ============================================================================
# REQUIRED — the script will fail without these
# ============================================================================

# Base domain — Coder will be at coder.<DOMAIN>, Dokploy at dokploy.<DOMAIN>
DOMAIN=example.com

# Cloudflare API token for wildcard SSL via DNS challenge
# Create at: Cloudflare Dashboard -> Profile -> API Tokens -> Create Token
# Permissions: Zone / DNS / Edit + Zone / Zone / Read
# Zone Resources: Include -> Specific zone -> your domain
CF_DNS_API_TOKEN=

# Email for Let's Encrypt certificate notifications
ACME_EMAIL=admin@example.com

# ============================================================================
# GitHub App — ONE app for Coder login + external auth + VK Remote + gh CLI
# ============================================================================
# Create with: scripts/infra/create-github-app.sh --domain $DOMAIN --project <name>
# Or manually: see docs/github-app-unified.md
#
# The SAME GitHub App client_id/secret is used for all three OAuth flows.
# The App ID + private key are used separately for scoped gh CLI tokens.

# OAuth credentials (from GitHub App settings page — NOT the App ID)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# External auth uses the SAME credentials (same GitHub App, different callback URL)
GITHUB_EXT_CLIENT_ID=
GITHUB_EXT_CLIENT_SECRET=

# GitHub App ID + private key for scoped gh CLI tokens in workspaces
# (installation-based tokens, separate from OAuth)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_B64=

# GitHub organization — users must be members to sign in
# Create a free org at: https://github.com/organizations/plan
GITHUB_ORG=

# ============================================================================
# OPTIONAL — sensible defaults are applied if not set
# ============================================================================

# Coder image version (default: v2.21.0)
#CODER_VERSION=v2.21.0

# Traefik image version (default: v3.6.7, matches Dokploy default)
#TRAEFIK_VERSION=v3.6.7

# Coder database password (auto-generated if empty)
#CODER_DB_PASSWORD=

# Docker group GID on the host (auto-detected if empty)
# Find with: getent group docker | cut -d: -f3
#DOCKER_GID=

# SSH key algorithm for Coder (default: rsa4096)
#CODER_SSH_KEYGEN_ALGORITHM=rsa4096

# ============================================================================
# HoliBot — Slack bot + agent execution service (set via Dokploy Environment tab)
# ============================================================================

# HoliBot container image tag (default: latest)
#HOLIBOT_IMAGE_TAG=latest

# Slack credentials — from https://api.slack.com/apps
# Bot Token (xoxb-): OAuth & Permissions → Bot User OAuth Token
#SLACK_BOT_TOKEN=
# App-Level Token (xapp-): Basic Information → App-Level Tokens (scope: connections:write)
#SLACK_APP_TOKEN=

# Coder API token for workspace status queries (from Coder UI: Settings > Tokens)
#CODER_API_TOKEN=

# Anthropic API key — required for Claude Code agent subprocess
#ANTHROPIC_API_KEY=

# GitHub PAT for agent git operations (repo + workflow scopes)
#HOLIBOT_GITHUB_TOKEN=

# Repository for agent to clone into /workspace/repo
#HOLIBOT_REPO_URL=

# Default branch for the target repository (default: main)
#HOLIBOT_REPO_BASE_BRANCH=main

# Agent execution limits (defaults shown)
#HOLIBOT_AGENT_MAX_TURNS=50
#HOLIBOT_AGENT_MAX_BUDGET_USD=5.00
#HOLIBOT_AGENT_TIMEOUT_MS=1800000

# HoliBot log level: fatal, error, warn, info, debug, trace (default: info)
#HOLIBOT_LOG_LEVEL=info

# ============================================================================
# VK Remote — optional OAuth and API keys
# ============================================================================

# Google OAuth for VK Remote login (optional)
#GOOGLE_OAUTH_CLIENT_ID=
#GOOGLE_OAUTH_SECRET=

# GitHub App ID for VK Remote — uses GITHUB_APP_ID from unified app above
# (no separate value needed; VK Remote compose references the same var)

# Loops email API key (optional — for email notifications)
#LOOPS_EMAIL_API_KEY=

# VK Remote secrets (auto-generated if empty)
#VK_REMOTE_JWT_SECRET=
#VK_REMOTE_ELECTRIC_PW=

# ============================================================================
# Post-setup — for --phase post-setup
# ============================================================================

# Dokploy API key (from Dokploy UI: Settings > Profile) — required for post-setup
#DOKPLOY_API_KEY=

# Coder session token (from Coder UI: Settings > Tokens) — optional
# Only needed for template upload; post-setup works without it (deploys services only)
#CODER_TOKEN=

# Email for Dokploy Let's Encrypt cert requests (default: ciekawy+dokploy@gmail.com)
#DOKPLOY_ACME_EMAIL=ciekawy+dokploy@gmail.com
