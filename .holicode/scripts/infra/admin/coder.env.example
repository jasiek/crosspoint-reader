# Admin config for update-coder-template.sh
#
# Copy to ~/.config/holicode/coder.env and fill in.
# Never commit this file — it points to the Coder server you administer
# and may reference a vault item containing an admin token.
#
# Companion file: ~/.config/holicode/template.tfvars
#   (copied + filled-in from scripts/infra/coder-template-x86/terraform.tfvars.example)

# Coder server URL (the deployment this admin workspace administers).
export CODER_URL="https://coder.example.com"

# Name of the template in the Coder server. Must already exist (created
# manually the first time, then updated by this script on subsequent runs).
export TEMPLATE_NAME="holicode-agentic"

# Optional: 1Password reference for the Coder admin token.
# If set, the script reads the token via `op read`.
# If unset, the script falls back to ~/.coder-token (chmod 600).
export CODER_TOKEN_OP_REF="op://Holagence/Coder Admin/token"
